<Window x:Class="DevPilotAgent.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:blazor="clr-namespace:Microsoft.AspNetCore.Components.WebView.Wpf;assembly=Microsoft.AspNetCore.Components.WebView.Wpf"
        xmlns:layout="clr-namespace:DevPilotAgent.App.Components.Layout"
        Title="DevPilot Agent" Height="900" Width="1400"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: WPF TopBar -->
        <DockPanel Grid.Row="0" Margin="10,10,10,5">
            <Label Content="프로젝트 폴더:" VerticalAlignment="Center"/>
            <Button Content="찾아보기" DockPanel.Dock="Right" Width="80" Padding="5,3"
                    Command="{Binding BrowseFolderCommand}" Margin="5,0,0,0"/>
            <TextBox Text="{Binding ProjectFolderPath, UpdateSourceTrigger=PropertyChanged}"
                     IsReadOnly="True" VerticalAlignment="Center" Padding="5,3"/>
        </DockPanel>

        <!-- Row 1: BlazorWebView -->
        <blazor:BlazorWebView Grid.Row="1" x:Name="BlazorWebView" HostPage="wwwroot/index.html">
            <blazor:BlazorWebView.RootComponents>
                <blazor:RootComponent Selector="#app" ComponentType="{x:Type layout:MainLayout}"/>
            </blazor:BlazorWebView.RootComponents>
        </blazor:BlazorWebView>

        <!-- Row 2: StatusBar -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
