<Window x:Class="DevPilotAgent.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:blazor="clr-namespace:Microsoft.AspNetCore.Components.WebView.Wpf;assembly=Microsoft.AspNetCore.Components.WebView.Wpf"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:layout="clr-namespace:DevPilotAgent.App.Components.Layout"
        Title="DevPilot Agent" Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontWeight="Regular"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Custom Title Bar -->
        <Grid Grid.Row="0" Background="{DynamicResource MaterialDesign.Brush.AppBar.Background}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- App Icon + Title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="RocketLaunch" Width="20" Height="20"
                                         Foreground="{DynamicResource PrimaryHueMidBrush}"
                                         VerticalAlignment="Center"/>
                <TextBlock Text="DevPilot Agent" Margin="8,0,0,0"
                           FontSize="14" FontWeight="Medium"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"/>
            </StackPanel>

            <!-- Window Control Buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="MinimizeButton" Style="{StaticResource MaterialDesignFlatButton}"
                        Width="46" Height="36" Padding="0" Click="MinimizeButton_Click">
                    <materialDesign:PackIcon Kind="WindowMinimize" Width="16" Height="16"/>
                </Button>
                <Button x:Name="MaximizeButton" Style="{StaticResource MaterialDesignFlatButton}"
                        Width="46" Height="36" Padding="0" Click="MaximizeButton_Click">
                    <materialDesign:PackIcon Kind="WindowMaximize" Width="16" Height="16"
                                             x:Name="MaximizeIcon"/>
                </Button>
                <Button x:Name="CloseButton" Style="{StaticResource MaterialDesignFlatButton}"
                        Width="46" Height="36" Padding="0" Click="CloseButton_Click">
                    <materialDesign:PackIcon Kind="WindowClose" Width="16" Height="16"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Row 1: Toolbar -->
        <Border Grid.Row="1" BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                BorderThickness="0,0,0,1" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Folder Icon + Path (clickable for recent projects) -->
                <materialDesign:PackIcon Grid.Column="0" Kind="FolderOpen" Width="20" Height="20"
                                         VerticalAlignment="Center"
                                         Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                <Button Grid.Column="1" Style="{StaticResource MaterialDesignFlatButton}"
                        HorizontalContentAlignment="Left" Padding="8,0,12,0"
                        Height="30" Command="{Binding ToggleProjectSelectorCommand}"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding ProjectFolderDisplay}"
                                   FontSize="13" Opacity="0.8"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="600" VerticalAlignment="Center"/>
                        <materialDesign:PackIcon Kind="ChevronDown" Width="16" Height="16"
                                                 Margin="4,0,0,0" VerticalAlignment="Center" Opacity="0.6"/>
                    </StackPanel>
                </Button>
                <Popup Grid.Column="1" PlacementTarget="{Binding ElementName=BlazorWebView}"
                       Placement="Top" StaysOpen="False"
                       IsOpen="{Binding ShowProjectSelector, Mode=TwoWay}"
                       AllowsTransparency="True">
                    <Border Background="{DynamicResource MaterialDesign.Brush.Background}"
                            BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                            BorderThickness="1" CornerRadius="6" Padding="4"
                            MinWidth="400" MaxHeight="300">
                        <StackPanel>
                            <TextBlock Text="최근 프로젝트" FontWeight="SemiBold" FontSize="12"
                                       Margin="12,8,12,4" Opacity="0.6"/>
                            <ItemsControl ItemsSource="{Binding RecentProjects}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                                HorizontalContentAlignment="Left"
                                                Padding="12,8" Height="Auto"
                                                Command="{Binding DataContext.SelectRecentProjectCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                WindowChrome.IsHitTestVisibleInChrome="True">
                                            <StackPanel>
                                                <TextBlock Text="{Binding ProjectName}" FontWeight="Medium" FontSize="13"/>
                                                <TextBlock Text="{Binding FolderPath}" FontSize="11" Opacity="0.6"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="380"/>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Popup>

                <!-- Browse Button -->
                <Button Grid.Column="2"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Content="변경" Height="30" Padding="12,0"
                        FontSize="12"
                        Command="{Binding BrowseFolderCommand}"
                        materialDesign:ButtonAssist.CornerRadius="4"
                        WindowChrome.IsHitTestVisibleInChrome="True"/>

                <!-- Settings Button -->
                <Button Grid.Column="3"
                        Style="{StaticResource MaterialDesignIconButton}"
                        Width="36" Height="36" Margin="8,0,0,0"
                        ToolTip="설정"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <materialDesign:PackIcon Kind="Cog" Width="20" Height="20"/>
                </Button>
            </Grid>
        </Border>

        <!-- Row 2: BlazorWebView -->
        <blazor:BlazorWebView Grid.Row="2" x:Name="BlazorWebView" HostPage="wwwroot/index.html">
            <blazor:BlazorWebView.RootComponents>
                <blazor:RootComponent Selector="#app" ComponentType="{x:Type layout:MainLayout}"/>
            </blazor:BlazorWebView.RootComponents>
        </blazor:BlazorWebView>

        <!-- Row 3: Status Bar -->
        <Border Grid.Row="3" Background="{DynamicResource MaterialDesign.Brush.AppBar.Background}"
                BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                BorderThickness="0,1,0,0" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- API Connection Status -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                             Fill="{Binding ApiStatusColor}"/>
                    <TextBlock Text="{Binding ApiStatusText}" FontSize="12" Opacity="0.8"/>
                </StackPanel>

                <!-- Separator -->
                <Border Grid.Column="1" Width="1" Height="14" Margin="12,0"
                        Background="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"/>

                <!-- Model Name -->
                <TextBlock Grid.Column="2"
                           Text="{Binding ModelDisplayName}"
                           FontSize="12" Opacity="0.7"
                           VerticalAlignment="Center"/>

                <!-- Work Status -->
                <TextBlock Grid.Column="3"
                           Text="{Binding StatusMessage}"
                           FontSize="12" Opacity="0.8"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
