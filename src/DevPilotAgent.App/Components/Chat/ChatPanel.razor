@using System.Net.Http
@using Microsoft.AspNetCore.Components
@using DevPilotAgent.App.Components.Services
@using DevPilotAgent.Shared.DTOs
@inject AnalysisApiService ApiService
@inject AnalysisHubService HubService
@inject AppStateService AppState
@inject MarkdownService Markdown
@implements IDisposable

<div class="chat-panel">
    <!-- Chat Messages Area -->
    <div class="chat-messages" id="chatMessages">
        @if (_messages.Count == 0 && !_isAnalyzing)
        {
            <div class="empty-state">
                <div class="empty-icon">&#x1F916;</div>
                <div class="empty-title">DevPilot Agent</div>
                <div class="empty-subtitle">에러 로그를 붙여넣고 분석을 요청하세요</div>
            </div>
        }
        @foreach (var msg in _messages)
        {
            <div class="chat-bubble @GetBubbleClass(msg.Type)">
                @if (msg.Type == ChatMessageType.Step)
                {
                    <div class="step-indicator">
                        <span class="step-badge">@msg.StepNumber/@msg.TotalSteps</span>
                        <span class="step-text">@msg.Content</span>
                    </div>
                }
                else if (msg.Type == ChatMessageType.User)
                {
                    <div class="bubble-content user-bubble">
                        <pre class="user-text">@msg.Content</pre>
                    </div>
                }
                else if (msg.Type == ChatMessageType.Agent)
                {
                    <div class="bubble-content markdown-body">@((MarkupString)Markdown.ToHtml(msg.Content))</div>
                }
                else
                {
                    <div class="bubble-content">@msg.Content</div>
                }
            </div>
        }
        @foreach (var (stepNumber, text) in _streamingTexts)
        {
            @if (!string.IsNullOrEmpty(text))
            {
                <div class="chat-bubble bubble-agent">
                    <div class="bubble-content markdown-body streaming-content">
                        @((MarkupString)Markdown.ToHtml(text))
                        <span class="cursor">|</span>
                    </div>
                </div>
            }
        }
    </div>

    <!-- Input Area (Bottom) -->
    <div class="chat-input-area">
        @if (string.IsNullOrWhiteSpace(AppState.ProjectFolderPath))
        {
            <div class="input-warning">
                <span class="warning-text">프로젝트 폴더를 먼저 선택하세요</span>
            </div>
        }
        <div class="input-row">
            <textarea @bind="_inputText"
                      @bind:event="oninput"
                      @onkeydown="HandleKeyDown"
                      placeholder="에러 로그를 붙여넣거나 메시지를 입력하세요..."
                      rows="3"
                      disabled="@_isAnalyzing"
                      class="chat-textarea"></textarea>
            <div class="input-buttons">
                @if (_isAnalyzing)
                {
                    <button class="btn btn-cancel btn-round" @onclick="CancelAnalysis" title="취소">
                        &#x25A0;
                    </button>
                    <span class="progress-text">@_currentStep/7</span>
                }
                else
                {
                    <button class="btn btn-primary btn-send" @onclick="SendMessage"
                            disabled="@(string.IsNullOrWhiteSpace(AppState.ProjectFolderPath) || string.IsNullOrWhiteSpace(_inputText))"
                            title="전송 (Enter)">
                        &#x27A4;
                    </button>
                }
            </div>
        </div>
        <div class="input-hint">
            <span>Enter 전송 | Shift+Enter 줄바꿈</span>
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback<AnalysisResponse?> OnAnalysisCompleted { get; set; }

    private string _inputText = string.Empty;
    private bool _isAnalyzing;
    private int _currentStep;
    private Guid? _currentAnalysisId;
    private readonly List<ChatMessageDto> _messages = [];
    private readonly Dictionary<int, string> _streamingTexts = [];

    protected override async Task OnInitializedAsync()
    {
        AppState.OnProjectFolderChanged += HandleFolderChanged;
        HubService.OnAgentStepUpdate += HandleStepUpdate;
        HubService.OnStreamChunk += HandleStreamChunk;
        HubService.OnAnalysisCompleted += HandleCompleted;

        try
        {
            await HubService.ConnectAsync();
        }
        catch
        {
            // API 서버 미실행 시 연결 실패 — UI는 정상 표시
        }
    }

    private void HandleFolderChanged(string _)
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task HandleKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessage();
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(AppState.ProjectFolderPath) || string.IsNullOrWhiteSpace(_inputText))
            return;

        var userText = _inputText.Trim();
        _inputText = string.Empty;

        _messages.Add(new ChatMessageDto(ChatMessageType.User, userText, DateTime.Now));

        await StartAnalysis(userText);
    }

    private async Task StartAnalysis(string errorLog)
    {
        _isAnalyzing = true;
        _currentStep = 0;
        _streamingTexts.Clear();

        _messages.Add(new ChatMessageDto(ChatMessageType.System, "분석을 시작합니다...", DateTime.Now));
        StateHasChanged();

        try
        {
            var request = new AnalysisRequest(AppState.ProjectFolderPath, errorLog);
            var started = await ApiService.StartAnalysisAsync(request);
            _currentAnalysisId = started.AnalysisId;

            await HubService.JoinAnalysisAsync(started.AnalysisId);
            await ApiService.TriggerAnalysisAsync(started.AnalysisId, request);
        }
        catch (HttpRequestException ex)
        {
            _isAnalyzing = false;
            _messages.Add(new ChatMessageDto(ChatMessageType.Error, $"API 서버 연결 실패: {ex.Message}", DateTime.Now));
        }
        catch (Exception ex)
        {
            _isAnalyzing = false;
            _messages.Add(new ChatMessageDto(ChatMessageType.Error, $"분석 시작 실패: {ex.Message}", DateTime.Now));
        }
        StateHasChanged();
    }

    private async Task CancelAnalysis()
    {
        if (_currentAnalysisId.HasValue)
        {
            await ApiService.CancelAnalysisAsync(_currentAnalysisId.Value);
            _isAnalyzing = false;
            _messages.Add(new ChatMessageDto(ChatMessageType.System, "분석이 취소되었습니다.", DateTime.Now));
            StateHasChanged();
        }
    }

    private void HandleStepUpdate(AgentStepMessage msg)
    {
        if (msg.AnalysisId != _currentAnalysisId) return;

        InvokeAsync(() =>
        {
            if (msg.Status == "Started")
            {
                _currentStep = msg.StepNumber;
                _messages.Add(new ChatMessageDto(
                    ChatMessageType.Step, msg.Message, DateTime.Now,
                    msg.StepName, msg.StepNumber, 7));
                _streamingTexts[msg.StepNumber] = "";
            }
            else if (msg.Status == "Completed")
            {
                _streamingTexts.Remove(msg.StepNumber);
                _messages.Add(new ChatMessageDto(
                    ChatMessageType.Agent, $"[완료] {msg.Message}", DateTime.Now));
            }
            StateHasChanged();
        });
    }

    private void HandleStreamChunk(StreamChunkMessage msg)
    {
        if (msg.AnalysisId != _currentAnalysisId) return;

        InvokeAsync(() =>
        {
            if (!msg.IsComplete)
            {
                if (!_streamingTexts.ContainsKey(msg.StepNumber))
                    _streamingTexts[msg.StepNumber] = "";
                _streamingTexts[msg.StepNumber] += msg.Chunk;
            }
            StateHasChanged();
        });
    }

    private void HandleCompleted(AnalysisCompletedMessage msg)
    {
        if (msg.AnalysisId != _currentAnalysisId) return;

        InvokeAsync(async () =>
        {
            _isAnalyzing = false;
            _streamingTexts.Clear();

            if (msg.Success)
            {
                _messages.Add(new ChatMessageDto(
                    ChatMessageType.Agent, "분석이 완료되었습니다. 우측 패널에서 결과를 확인하세요.", DateTime.Now));
                var result = await ApiService.GetAnalysisAsync(msg.AnalysisId);
                await OnAnalysisCompleted.InvokeAsync(result);
            }
            else
            {
                _messages.Add(new ChatMessageDto(
                    ChatMessageType.Error, $"분석 실패: {msg.ErrorMessage}", DateTime.Now));
            }

            if (_currentAnalysisId.HasValue)
                await HubService.LeaveAnalysisAsync(_currentAnalysisId.Value);

            StateHasChanged();
        });
    }

    private static string GetBubbleClass(ChatMessageType type) => type switch
    {
        ChatMessageType.User => "bubble-user",
        ChatMessageType.Agent => "bubble-agent",
        ChatMessageType.System => "bubble-system",
        ChatMessageType.Step => "bubble-step",
        ChatMessageType.Error => "bubble-error",
        _ => "bubble-agent"
    };

    public void Dispose()
    {
        AppState.OnProjectFolderChanged -= HandleFolderChanged;
        HubService.OnAgentStepUpdate -= HandleStepUpdate;
        HubService.OnStreamChunk -= HandleStreamChunk;
        HubService.OnAnalysisCompleted -= HandleCompleted;
    }
}
